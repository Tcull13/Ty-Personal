# ===========================================
# REQUIRED - App Won't Run Without These
# ===========================================

# Database (Get free one from https://neon.tech)
DATABASE_URL="postgresql://user:password@localhost:5432/affiliate_pin_automation"

# NextAuth (For login/signup)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-string-at-least-32-characters-long"

# App Settings
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===========================================
# NEEDED FOR AI PIN GENERATION
# ===========================================

# OpenAI API Key (Get from https://platform.openai.com)
# Costs ~$0.05 per pin generated
OPENAI_API_KEY=""

# Your Amazon Affiliate Tag (from Amazon Associates program)
AMAZON_ASSOCIATE_TAG="your-affiliate-tag-20"

# ===========================================
# NEEDED FOR AUTO-POSTING TO PINTEREST
# ===========================================

# Pinterest API (Get from https://developers.pinterest.com)
# Requires app approval (takes 1-3 days)
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
PINTEREST_REDIRECT_URI="http://localhost:3000/api/auth/pinterest/callback"

# ===========================================
# NEEDED FOR ACCEPTING PAYMENTS
# ===========================================

# Stripe (Get from https://dashboard.stripe.com)
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (Create products in Stripe, then copy price IDs)
STRIPE_PRICE_ID_BASIC=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_ENTERPRISE=""

# ===========================================
# OPTIONAL - App Works Without These
# ===========================================

# Google OAuth (For "Sign in with Google")
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cron Secret (For scheduled posting)
CRON_SECRET="your-random-cron-secret"

# Amazon Product API (Not required - app uses web scraping by default)
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""

# Canva API (Future feature - not implemented yet)
CANVA_CLIENT_ID=""
CANVA_CLIENT_SECRET=""

# ===========================================
# WHAT YOU NEED TO START
# ===========================================
# Minimum to test locally:
# 1. DATABASE_URL (free from neon.tech)
# 2. NEXTAUTH_SECRET (just make up a random long string)
# 3. OPENAI_API_KEY (if you want to test AI generation)
# 4. AMAZON_ASSOCIATE_TAG (your affiliate tag)
#
# Everything else can be added later!
