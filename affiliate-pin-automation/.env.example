# Database
DATABASE_URL="postgresql://user:password@localhost:5432/affiliate_pin_automation"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe
STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs for subscription tiers
STRIPE_PRICE_ID_BASIC=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_ENTERPRISE=""

# Pinterest API
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""
PINTEREST_REDIRECT_URI="http://localhost:3000/api/auth/pinterest/callback"

# Canva API (optional - for template integration)
CANVA_CLIENT_ID=""
CANVA_CLIENT_SECRET=""

# OpenAI (for AI-generated pin text and images)
OPENAI_API_KEY=""

# Amazon Associates (for product scraping)
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_ASSOCIATE_TAG="your-affiliate-tag"

# App Settings
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Rate Limiting
MAX_PINS_PER_DAY_FREE=3
MAX_PINS_PER_DAY_BASIC=20
MAX_PINS_PER_DAY_PRO=100
MAX_PINS_PER_DAY_ENTERPRISE=500
